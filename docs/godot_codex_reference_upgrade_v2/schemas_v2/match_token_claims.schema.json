{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MatchTokenClaims",
  "type": "object",
  "required": [
    "iss",
    "aud",
    "match_id",
    "user_id",
    "player_id",
    "team_id",
    "hero_id",
    "exp_ms"
  ],
  "properties": {
    "iss": {
      "const": "nakama"
    },
    "aud": {
      "const": "godot-match-server"
    },
    "match_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "player_id": {
      "type": "string"
    },
    "team_id": {
      "type": "integer",
      "minimum": 1
    },
    "hero_id": {
      "type": "string"
    },
    "exp_ms": {
      "type": "integer",
      "minimum": 0
    }
  }
}
