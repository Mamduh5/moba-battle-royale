{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InputFrame",
  "type": "object",
  "required": [
    "input_sequence",
    "client_tick",
    "move",
    "aim",
    "buttons",
    "cast_requests"
  ],
  "properties": {
    "input_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "client_tick": {
      "type": "integer",
      "minimum": 0
    },
    "move": {
      "$ref": "#/$defs/vec2_unit"
    },
    "aim": {
      "$ref": "#/$defs/vec2_unit"
    },
    "buttons": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "cast_requests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cast_request"
      }
    }
  },
  "$defs": {
    "vec2_unit": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      }
    },
    "cast_request": {
      "type": "object",
      "required": [
        "slot",
        "ability_id",
        "target_position",
        "aim"
      ],
      "properties": {
        "slot": {
          "type": "string"
        },
        "ability_id": {
          "type": "string"
        },
        "target_entity_id": {
          "type": "integer",
          "minimum": 0
        },
        "target_position": {
          "type": "object"
        },
        "aim": {
          "$ref": "#/$defs/vec2_unit"
        }
      }
    }
  }
}
