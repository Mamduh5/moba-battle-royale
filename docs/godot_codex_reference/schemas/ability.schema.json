{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ability.schema.json",
  "title": "AbilityDefinition",
  "type": "object",
  "required": [
    "schema_version",
    "content_version",
    "id",
    "slot",
    "targeting",
    "cooldown",
    "behavior",
    "server_validation",
    "presentation"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "content_version": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^ability_[a-z0-9_]+$"
    },
    "slot": {
      "type": "string",
      "enum": [
        "basic",
        "skill_1",
        "skill_2",
        "ultimate",
        "passive",
        "item"
      ]
    },
    "targeting": {
      "type": "string",
      "enum": [
        "self",
        "unit",
        "point",
        "direction",
        "cone",
        "line",
        "circle",
        "zone",
        "dash",
        "lock_on",
        "passive"
      ]
    },
    "range": {
      "type": "number",
      "minimum": 0
    },
    "radius": {
      "type": "number",
      "minimum": 0
    },
    "width": {
      "type": "number",
      "minimum": 0
    },
    "speed": {
      "type": "number",
      "minimum": 0
    },
    "lifetime": {
      "type": "number",
      "minimum": 0
    },
    "cast_time": {
      "type": "number",
      "minimum": 0
    },
    "channel_time": {
      "type": "number",
      "minimum": 0
    },
    "cooldown": {
      "type": "number",
      "minimum": 0
    },
    "charges": {
      "type": "integer",
      "minimum": 0
    },
    "resource_cost": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "behavior": {
      "type": "string"
    },
    "damage": {
      "type": "object",
      "additionalProperties": true
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "server_validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "presentation": {
      "type": "object",
      "required": [
        "icon_key",
        "cast_vfx_key"
      ],
      "additionalProperties": {
        "type": "string"
      }
    },
    "last_balance_note": {
      "type": "string"
    }
  }
}
