{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/match_event.schema.json",
  "title": "MatchEvent",
  "type": "object",
  "required": [
    "event_type",
    "match_id",
    "server_tick",
    "time_ms",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "event_type": {
      "type": "string"
    },
    "match_id": {
      "type": "string"
    },
    "server_tick": {
      "type": "integer",
      "minimum": 0
    },
    "time_ms": {
      "type": "integer",
      "minimum": 0
    },
    "source_entity_id": {
      "type": "string"
    },
    "target_entity_id": {
      "type": "string"
    },
    "player_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
